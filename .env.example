# OPENAI SETTINGS
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=http://localhost:20128/v1

# OPENAI-COMPATIBLE LAB API SETTINGS
# The app also accepts loose ".env" lines like:
# host: http://localhost:20128/v1
# api_key1: your_primary_key
# api_key2: your_backup_key
# model: xmtp/mimo-v2.5, xmtp/mimo-v2.5-pro

# GEMINI SETTINGS
GEMINI_API_KEY=your_gemini_api_key_here

# OPTIONAL LOCAL GGUF SETTINGS (legacy test helper)
LOCAL_MODEL_PATH=./models/Phi-3-mini-4k-instruct-q4.gguf

# LAB CONFIG
# Options: openai | google
DEFAULT_PROVIDER=openai
# Leave blank to use the first model from "model:" in .env.
DEFAULT_MODEL=xmtp/mimo-v2.5
LOG_LEVEL=INFO
